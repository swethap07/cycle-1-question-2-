#include <stdio.h>

int largest(int a, int b, int c)
{
    if(a > b)
    {
        if(a > c)
            return a;
        else
            return c;
    }
    else
    {
        if(b > c)
            return b;
        else
            return c;
    }
}

int smallest(int a, int b, int c)
{
    if(a < b && a < c)
        return a;
    else if(b < a && b < c)
        return b;
    else
        return c;
}


float average(int a, int b, int c)
{
    float avg;
    int V;

    avg = (a + b + c) / 3.0;

    V = (avg >= 50) ? 1 : 0;

    printf("Average = %.2f\n", avg);
    printf("V = %d\n", V);

    return avg;
}

int main()
{
    int m1, m2, m3;
    int L, S;

    printf("Enter marks of three subjects: ");
    scanf("%d %d %d", &m1, &m2, &m3);

    L = largest(m1, m2, m3);
    S = smallest(m1, m2, m3);

    printf("Largest mark = %d\n", L);
    printf("Smallest mark = %d\n", S);
    average(m1, m2, m3);
    return 0;
}
